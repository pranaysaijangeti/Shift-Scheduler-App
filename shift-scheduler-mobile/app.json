{
  "expo": {
    "name": "Shift Scheduler",
    "slug": "shift-scheduler-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shiftscheduler.app",
      "infoPlist": {
        "NSCalendarsUsageDescription": "This app needs access to your calendar to create shift events.",
        "NSRemindersUsageDescription": "This app needs access to your reminders to set shift alarms.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photos to upload shift schedules.",
        "NSCameraUsageDescription": "This app needs access to your camera to capture shift schedules."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.shiftscheduler.app",
      "permissions": [
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA"
      ]
    },
    "web": {
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#ffffff"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to upload shift schedules."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      },
      "API_BASE_URL": "http://10.0.0.152:5000/api",
      "APP_NAME": "Shift Scheduler",
      "APP_VERSION": "1.0.0"
    }
  }
}
